{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Cynrath/agent-context-kit/blob/master/docs/schemas/ackit-baseline-v1.schema.json",
  "title": "AgentContextKit baseline manifest schema v1",
  "type": "object",
  "required": ["schemaVersion", "fingerprintAlgorithm", "entries"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "fingerprintAlgorithm": { "const": "sha256-rule-path-location-occurrence-v1" },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["fingerprint", "ruleId", "path", "severity", "startLine", "startColumn", "occurrence"],
        "properties": {
          "fingerprint": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "ruleId": { "type": "string", "pattern": "^ACKIT[0-9]{3}$" },
          "path": { "type": "string", "minLength": 1 },
          "severity": { "type": "string" },
          "startLine": { "type": ["integer", "null"], "minimum": 1 },
          "startColumn": { "type": ["integer", "null"], "minimum": 1 },
          "occurrence": { "type": "integer", "minimum": 1 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
