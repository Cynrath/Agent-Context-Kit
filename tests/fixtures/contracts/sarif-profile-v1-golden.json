{
  "$schema": "https://json.schemastore.org/sarif-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "AgentContextKit",
          "informationUri": "https://github.com/Cynrath/agent-context-kit",
          "version": "0.2.0-alpha.1",
          "rules": [
            {
              "id": "ACKIT003",
              "name": "GeneratedOrBuildArtifact",
              "shortDescription": { "text": "Generated artifact review finding." },
              "fullDescription": { "text": "Generated artifact review finding with sanitized metadata." },
              "help": { "text": "Keep generated artifacts outside tracked source." }
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "ACKIT003",
          "level": "warning",
          "message": { "text": "Generated artifact requires review." },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": { "uri": "artifacts/example-package.nupkg" }
              }
            }
          ]
        }
      ]
    }
  ]
}
